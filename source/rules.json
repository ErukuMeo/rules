        { "type": "domain_suffix", "value": "perplexity.ai" }
      ]
    },
    {
      "id": "streaming",
      "description": "Global streaming media services",
      "policy": "STREAMING",
      "priority": 20,
      "enabled": true,
      "source": "manual",
      "notes": "Global media services routed to streaming policy groups.",
      "rules": [
        { "type": "domain_suffix", "value": "netflix.com" },
        { "type": "domain_suffix", "value": "nflxvideo.net" },
