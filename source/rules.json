        { "type": "domain_suffix", "value": "apple.com" },
        { "type": "domain_suffix", "value": "icloud.com" },
        { "type": "domain_suffix", "value": "mzstatic.com" },
        { "type": "domain_suffix", "value": "itunes.apple.com" }
      ]
    },
    {
      "id": "microsoft",
      "description": "Microsoft and GitHub services",
      "policy": "MICROSOFT",
      "priority": 40,
      "enabled": true,
      "source": "manual",
      "notes": "Microsoft, Office, Windows Update, and GitHub related domains.",
