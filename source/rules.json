        { "type": "domain_suffix", "value": "github.com" },
        { "type": "domain_suffix", "value": "githubusercontent.com" }
      ]
    },
    {
      "id": "google",
      "description": "Google services",
      "policy": "GOOGLE",
      "priority": 50,
      "enabled": true,
      "source": "manual",
      "notes": "Google search, account, API, and static asset domains.",
      "rules": [
        { "type": "domain_suffix", "value": "google.com" },
        { "type": "domain_suffix", "value": "googleapis.com" },
        { "type": "domain_suffix", "value": "gstatic.com" },
        { "type": "domain_suffix", "value": "googleusercontent.com" },
        { "type": "domain_suffix", "value": "gmail.com" },
        { "type": "domain_suffix", "value": "google.com.hk" }
