    {
      "id": "developer",
      "description": "Developer tools and package registries",
      "policy": "DEVELOPER",
      "priority": 60,
      "enabled": true,
      "source": "manual",
      "notes": "Common developer services that benefit from a dedicated policy group.",
      "rules": [
        { "type": "domain_suffix", "value": "docker.com" },
        { "type": "domain_suffix", "value": "docker.io" },
        { "type": "domain_suffix", "value": "npmjs.com" },
