{
  "version": 1,
  "repository": {
    "owner": "ErukuMeo",
    "name": "rules",
    "branch": "main"
  },
  "policies": {
    "ai": "AI",
    "streaming": "STREAMING",
    "apple": "APPLE",
    "microsoft": "MICROSOFT",
    "google": "GOOGLE",
    "developer": "DEVELOPER",
    "games": "GAMES",
    "download": "DOWNLOAD",
    "cn": "DIRECT",
    "proxy": "PROXY",
    "direct": "DIRECT",
    "reject": "REJECT",
    "final": "FINAL"
  },
  "categories": [
    {
      "id": "ai",
      "description": "AI services and model providers",
      "policy": "AI",
      "priority": 10,
      "enabled": true,
      "source": "manual",
      "notes": "High-priority AI services that commonly require proxy routing.",
      "rules": [
        { "type": "domain_suffix", "value": "openai.com" },
        { "type": "domain_suffix", "value": "chatgpt.com" },
        { "type": "domain_suffix", "value": "oaistatic.com" },
