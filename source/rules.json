    {
      "id": "download",
      "description": "Download and release distribution services",
      "policy": "DOWNLOAD",
      "priority": 80,
      "enabled": true,
      "source": "manual",
      "notes": "Large download and release distribution domains.",
      "rules": [
        { "type": "domain_suffix", "value": "github-releases.githubusercontent.com" },
        { "type": "domain_suffix", "value": "objects.githubusercontent.com" },
        { "type": "domain_suffix", "value": "sourceforge.net" },
        { "type": "domain_suffix", "value": "fosshub.com" },
        { "type": "domain_suffix", "value": "archive.org" }
      ]
    },
    {
      "id": "cn",
      "description": "Mainland China direct rules",
      "policy": "DIRECT",
      "priority": 90,
      "enabled": true,
      "source": "manual",
      "notes": "Direct routing for mainland China geo and common domestic services.",
      "rules": [
        { "type": "geosite", "value": "cn" },
        { "type": "geoip", "value": "cn" },
        { "type": "domain_suffix", "value": "bilibili.com" },
        { "type": "domain_suffix", "value": "qq.com" },
        { "type": "domain_suffix", "value": "taobao.com" },
        { "type": "domain_suffix", "value": "jd.com" }
      ]
    },
    {
      "id": "proxy",
      "description": "General proxy rules",
      "policy": "PROXY",
      "priority": 100,
      "enabled": true,
      "source": "manual",
      "notes": "General non-China proxy fallback rules.",
      "rules": [
        { "type": "geosite", "value": "geolocation-!cn" },
        { "type": "domain_suffix", "value": "google.com" },
        { "type": "domain_suffix", "value": "telegram.org" },
        { "type": "domain_suffix", "value": "x.com" },
        { "type": "domain_suffix", "value": "twitter.com" }
      ]
    },
    {
      "id": "direct",
      "description": "Always direct rules",
      "policy": "DIRECT",
      "priority": 110,
      "enabled": true,
      "source": "manual",
      "notes": "Localhost and private networks must bypass proxy handling.",
      "rules": [
        { "type": "domain", "value": "localhost" },
        { "type": "ip_cidr", "value": "10.0.0.0/8" },
        { "type": "ip_cidr", "value": "172.16.0.0/12" },
        { "type": "ip_cidr", "value": "192.168.0.0/16" },
        { "type": "ip_cidr", "value": "127.0.0.0/8" }
      ]
    },
    {
      "id": "reject",
      "description": "Advertising and tracking reject rules",
      "policy": "REJECT",
      "priority": 120,
      "enabled": true,
      "source": "manual",
      "notes": "Basic advertising and analytics rejection rules.",
      "rules": [
        { "type": "domain_suffix", "value": "doubleclick.net" },
        { "type": "domain_suffix", "value": "googlesyndication.com" },
        { "type": "domain_suffix", "value": "google-analytics.com" },
        { "type": "domain_keyword", "value": "adservice" }
      ]
    }
  ]
}
